{
  "description": "Ship-flow plugin hooks — (1) PreToolUse warn on direct Read/Edit of active entity files (Principle #5c); (2) SessionStart warn on FO state drift (PR merged but entity still status: ship). See plugins/ship-flow/INVARIANTS.md.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/warn-direct-read.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/warn-state-drift.sh\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
